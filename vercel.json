{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(index|gallery|artwork|profile|upload|docs-protocol)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs.html",
      "destination": "/docs-protocol.html",
      "permanent": true
    },
    {
      "source": "/auction-system.html",
      "destination": "/docs-protocol.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:route*",
      "destination": "/api/[...route]?route=auth/:route*"
    },
    {
      "source": "/api/discovery/:route*",
      "destination": "/api/[...route]?route=discovery/:route*"
    },
    {
      "source": "/api/public/:route*",
      "destination": "/api/[...route]?route=public/:route*"
    },
    {
      "source": "/api/upload/:route*",
      "destination": "/api/[...route]?route=upload/:route*"
    },
    {
      "source": "/api/functions/:route*",
      "destination": "/api/[...route]?route=functions/:route*"
    },
    {
      "source": "/api/moderation/:route*",
      "destination": "/api/[...route]?route=moderation/:route*"
    },
    {
      "source": "/api/oauth/:route*",
      "destination": "/api/[...route]?route=oauth/:route*"
    },
    {
      "source": "/api/ai/:route*",
      "destination": "/api/[...route]?route=ai/:route*"
    },
    {
      "source": "/api/profile",
      "destination": "/api/[...route]?route=profile"
    },
    {
      "source": "/api/artworks",
      "destination": "/api/[...route]?route=artworks"
    },
    {
      "source": "/api/auctions",
      "destination": "/api/[...route]?route=auctions"
    }
  ]
}
