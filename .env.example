# ArtSoul local environment template
# Copy this file to .env and fill values locally. Never commit real secrets.

# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only Supabase key. Keep local/secret only.
SUPABASE_SERVICE_ROLE_KEY=

# Database and server secrets
DATABASE_URL=
SESSION_SECRET=

# Blockchain RPC configuration
BASE_SEPOLIA_RPC_URL=
ETH_SEPOLIA_RPC_URL=
# Optional fallback only. Prefer chain-specific RPC URLs above for production.
RPC_URL=

# Deployment wallet. Use a fresh testnet-only key and rotate if ever exposed.
PRIVATE_KEY=
TREASURY_ADDRESS=

# Canonical V4.1 contract addresses after deployment
ARTSOUL_CORE_ADDRESS=0x0000000000000000000000000000000000000000
ARTSOUL_NFT_ADDRESS=0x0000000000000000000000000000000000000000
ARTSOUL_PROJECT_NFT_ADDRESS=0x0000000000000000000000000000000000000000
ARTSOUL_CORE_ADDRESS_BASE_SEPOLIA=0x43368f7E2d5f11f4B7E11928D66d3f4A5a4E4ceF
ARTSOUL_NFT_ADDRESS_BASE_SEPOLIA=0xf061f70503c37Cf2196A28F4785E524D0Fb32538
ARTSOUL_PROJECT_NFT_ADDRESS_BASE_SEPOLIA=0xBd17c875962a3cd34F10405234527a41A90A682B
ARTSOUL_CORE_ADDRESS_ETH_SEPOLIA=0x43368f7E2d5f11f4B7E11928D66d3f4A5a4E4ceF
ARTSOUL_NFT_ADDRESS_ETH_SEPOLIA=0xf061f70503c37Cf2196A28F4785E524D0Fb32538
ARTSOUL_PROJECT_NFT_ADDRESS_ETH_SEPOLIA=0xBd17c875962a3cd34F10405234527a41A90A682B

# Indexer runtime
ARTSOUL_INDEXER_CHAINS=base-sepolia,eth-sepolia
ARTSOUL_INDEXER_CHAIN=eth-sepolia
ARTSOUL_INDEXER_CHAIN_ID=11155111
BASE_SEPOLIA_CHAIN_ID=84532
ETH_SEPOLIA_CHAIN_ID=11155111
BASE_SEPOLIA_START_BLOCK=41976861
ETH_SEPOLIA_START_BLOCK=10920477
INDEXER_START_BLOCK=0
INDEXER_CONFIRMATION_DEPTH=12
INDEXER_POLL_INTERVAL=15000
INDEXER_MAX_BLOCK_RANGE=10
INDEXER_HEALTH_PORT=3001

# Optional Redis-backed cache/work queues. Leave empty to run indexer without Redis.
REDIS_URL=

# Optional server-side AI valuation key. Never expose this to browser code.
GEMINI_API_KEY=
